{
    "id": "com.fvtronics.quire",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "quire",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
          "CARGO_NET_OFFLINE": "true"
        }
    },
    "modules": [
        {
            "name": "quire",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                },
                "../cargo-sources.json"
            ],
            "config-opts": ["-Dcargo-home=/run/build/quire/cargo"]
        }
    ]
}
