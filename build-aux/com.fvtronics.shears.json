{
    "id": "com.fvtronics.shears",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "shears",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
          "CARGO_NET_OFFLINE": "true"
        }
    },
    "modules": [
        {
            "name": "poppler",
            "buildsystem": "cmake-ninja",
            "cleanup": [
                "/include",
                "/lib/pkgconfig"
            ],
            "config-opts": [
                "-DBUILD_GTK_TESTS=OFF",
                "-DRUN_GPERF_IF_PRESENT=OFF",
                "-DENABLE_GOBJECT_INTROSPECTION=OFF",
                "-DENABLE_UTILS=OFF",
                "-DENABLE_CPP=OFF",
                "-DENABLE_GLIB=ON",
                "-DENABLE_LIBOPENJPEG=openjpeg2",
                "-DENABLE_LIBCURL=OFF",
                "-DENABLE_LIBTIFF=OFF",
                "-DENABLE_BOOST=OFF",
                "-DENABLE_NSS3=OFF",
                "-DENABLE_GPGME=OFF",
                "-DENABLE_QT5=OFF",
                "-DENABLE_QT6=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://poppler.freedesktop.org/poppler-26.07.0.tar.xz",
                    "sha256": "304832f48f8a47fdca90c6b6d1f684e68f37c10c9a0726f345f4ca9df4ca01e2"
                }
            ]
        },
        {
            "name": "shears",
            "buildsystem": "meson",
            "sources": [
                {
                  "type": "dir",
                  "path": "../"
                },
                "../cargo-sources.json"
            ],
            "config-opts": ["-Dcargo-home=/run/build/shears/cargo"]
        }
    ]
}
