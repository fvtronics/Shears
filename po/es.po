#: data/com.fvtronics.quire.metainfo.xml.in.in:10
msgid ""
"Quire is a simple GNOME utility for working with local PDF files without a "
"complex document suite."
msgstr ""
"Quire es una utilidad sencilla de GNOME para trabajar con archivos PDF "
"locales sin una suite ofimática compleja."

#: data/com.fvtronics.quire.metainfo.xml.in.in:11
msgid "Merge PDFs without relying on online services."
msgstr "Combine archivos PDF sin enviarlos a un servicio en línea"

#: data/com.fvtronics.quire.metainfo.xml.in.in:16
msgid "Merge multiple PDF files into a single document"
msgstr "Combinar varios archivos PDF en un solo documento"

#: data/com.fvtronics.quire.metainfo.xml.in.in:27
msgid "New"
msgstr "Nuevo"

#: data/com.fvtronics.quire.metainfo.xml.in.in:29
msgid "Add support for opening password protected files"
msgstr "Se añadió soporte para archivos protegidos con contraseña"

#: data/com.fvtronics.quire.metainfo.xml.in.in:30
msgid "Add option to insert blank page"
msgstr "Se añadió una opción para insertar páginas en blanco"

#: data/com.fvtronics.quire.metainfo.xml.in.in:31
msgid "Add option to duplicate a file in the list view"
msgstr "Se añadió una opción para duplicar un archivo en la vista de lista"

#: data/com.fvtronics.quire.metainfo.xml.in.in:33
msgid "Changes"
msgstr "Cambios"

#: data/com.fvtronics.quire.metainfo.xml.in.in:35
