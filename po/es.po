#: data/com.fvtronics.quire.metainfo.xml.in.in:59
#: data/com.fvtronics.quire.metainfo.xml.in.in:73
msgid "Changes"
msgstr "Cambios"

#: data/com.fvtronics.quire.metainfo.xml.in.in:61
msgid "Make the open file action in the merge page more intuitive"
