#: data/com.fvtronics.quire.metainfo.xml.in.in:10
msgid ""
"Quire is a simple GNOME utility for working with local PDF files without a "
"complex document suite."
msgstr ""
"Quire es una utilidad sencilla de GNOME para trabajar con archivos PDF "
"locales sin una suite ofimática compleja."

#: data/com.fvtronics.quire.metainfo.xml.in.in:11
msgid "Merge PDFs without relying on online services."
msgstr "Combine archivos PDF sin enviarlos a un servicio en línea"

#: data/com.fvtronics.quire.metainfo.xml.in.in:16
msgid "Merge multiple PDF files into a single document"
msgstr "Combinar varios archivos PDF en un solo documento"

#: data/com.fvtronics.quire.metainfo.xml.in.in:20
msgid "Split a PDF into multiple documents"
msgstr "Divida un archivo PDF en múltiples documentos"

#: data/com.fvtronics.quire.metainfo.xml.in.in:31
#: data/com.fvtronics.quire.metainfo.xml.in.in:43
msgid "New"
msgstr "Nuevo"

#: data/com.fvtronics.quire.metainfo.xml.in.in:33
msgid "Add the split PDF functionality"
msgstr "Se añadió la funcionalidad de dividir un archivo PDF"

#: data/com.fvtronics.quire.metainfo.xml.in.in:35
#: data/com.fvtronics.quire.metainfo.xml.in.in:49
msgid "Changes"
msgstr "Cambios"

#: data/com.fvtronics.quire.metainfo.xml.in.in:37
msgid "Make the open file action in the merge page more intuitive"
msgstr ""
"La acción de abrir archivo en la sección de combinar se archivos se hizo más "
"intuitiva"

#: data/com.fvtronics.quire.metainfo.xml.in.in:45
msgid "Add support for opening password protected files"
msgstr "Se añadió soporte para archivos protegidos con contraseña"

#: data/com.fvtronics.quire.metainfo.xml.in.in:46
msgid "Add option to insert blank page"
msgstr "Se añadió una opción para insertar páginas en blanco"

#: data/com.fvtronics.quire.metainfo.xml.in.in:47
msgid "Add option to duplicate a file in the list view"
msgstr "Se añadió una opción para duplicar un archivo en la vista de lista"

#: data/com.fvtronics.quire.metainfo.xml.in.in:51
msgid "Collapse secondary options into a menu"
msgstr "Colapsar opciones secundarias en un menú"

# Se adaptó este texto para que haga sentido
#: data/com.fvtronics.quire.metainfo.xml.in.in:52
msgid "Add handler to rows for drag and drop"
msgstr "Añadir un ícono para arrastrar las filas"

#: data/com.fvtronics.quire.metainfo.xml.in.in:58
msgid "Initial release"
msgstr "Lanzamiento inicial"

#: data/com.fvtronics.quire.metainfo.xml.in.in:60
