#: data/com.fvtronics.quire.metainfo.xml.in.in:45
msgid "Make the open file action in the merge page more intuitive"
msgstr ""
"La acción de abrir archivo en la sección de combinar se archivos se hizo más "
"intuitiva"

#: data/com.fvtronics.quire.metainfo.xml.in.in:53
msgid "Add support for opening password protected files"
msgstr "Se añadió soporte para archivos protegidos con contraseña"

#: data/com.fvtronics.quire.metainfo.xml.in.in:54
msgid "Add option to insert blank page"
msgstr "Se añadió una opción para insertar páginas en blanco"

#: data/com.fvtronics.quire.metainfo.xml.in.in:55
msgid "Add option to duplicate a file in the list view"
msgstr "Se añadió una opción para duplicar un archivo en la vista de lista"

#: data/com.fvtronics.quire.metainfo.xml.in.in:59
msgid "Collapse secondary options into a menu"
