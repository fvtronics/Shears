#: data/com.fvtronics.shears.metainfo.xml.in.in:10
msgid ""
"Shears is a simple GNOME utility for working with local PDF files without a "
"complex document suite."
msgstr ""
"Shears es una utilidad sencilla de GNOME para trabajar con archivos PDF "
"locales sin una suite ofimática compleja."

#: data/com.fvtronics.shears.metainfo.xml.in.in:11
msgid ""
"Merge multiple PDFs, organize pages, extract page ranges, split documents, "
"compress files, and edit metadata without relying on online services."
msgstr ""
"Combine varios archivos PDF, organice páginas, extraiga rangos de páginas, "
"divida documentos, comprima archivos y edite los metadatos sin enviarlos a "
"un servicio en línea."

#: data/com.fvtronics.shears.metainfo.xml.in.in:16
msgid "Merge multiple PDF files into a single document"
msgstr "Combine varios archivos PDF en un solo documento"

#: data/com.fvtronics.shears.metainfo.xml.in.in:20
msgid "Organize and remove a document's pages"
msgstr "Organice y remueva las páginas de un documento"

#: data/com.fvtronics.shears.metainfo.xml.in.in:24
msgid "Extract selected pages into a new document"
msgstr "Extraiga páginas seleccionadas en un nuevo documento"

#: data/com.fvtronics.shears.metainfo.xml.in.in:28
msgid "Split a PDF into multiple documents"
msgstr "Divida un archivo PDF en múltiples documentos"

#: data/com.fvtronics.shears.metainfo.xml.in.in:32
msgid "Compress a PDF file"
msgstr "Comprimir un archivo PDF"

#: data/com.fvtronics.shears.metainfo.xml.in.in:36
msgid "Add a watermark to specific PDF pages"
msgstr "Añada una marca de agua a páginas específicas"

#: data/com.fvtronics.shears.metainfo.xml.in.in:40
msgid "View and edit PDF metadata"
msgstr "Visualice y edite los metadatos de un archivo PDF"

