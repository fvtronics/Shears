msgid "New"
msgstr "Nuevo"

#: data/com.fvtronics.quire.metainfo.xml.in.in:33
msgid "Add section to visualize and edit a document's metadata"
msgstr ""
"Se añadió una sección para visualizar y editar los metadatos de un documento"

#: data/com.fvtronics.quire.metainfo.xml.in.in:41
msgid "Add the split PDF functionality"
msgstr "Se añadió la funcionalidad de dividir un archivo PDF"

#: data/com.fvtronics.quire.metainfo.xml.in.in:43
#: data/com.fvtronics.quire.metainfo.xml.in.in:57
msgid "Changes"
