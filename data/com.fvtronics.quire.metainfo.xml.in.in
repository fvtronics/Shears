<?xml version="1.0" encoding="UTF-8"?>
<!-- Francisco Vásquez Cuevas 2019 <fvasquez.public@fvtronics.com> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Quire</name>
  <summary>Combine and edit PDF files</summary>
  <description>
    <p>Quire is a simple GNOME utility for working with local PDF files without a complex document suite.</p>
    <p>Merge PDFs without relying on online services.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.1/data/resources/screenshots/merge.png</image>
      <caption>Merge multiple PDF files into a single document</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.1/data/resources/screenshots/split.png</image>
      <caption>Split a PDF into multiple documents</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/quire/raw/tag/v0.2.1/data/resources/screenshots/metadata.png</image>
      <caption>View and edit PDF metadata</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://www.fvtronics.com/en/project/quire</url>
  <url type="bugtracker">https://codeberg.org/fvtronics/quire/issues</url>
  <url type="vcs-browser">https://codeberg.org/fvtronics/quire</url>
  <url type="translate">https://codeberg.org/translate/Quire/src/branch/main/po</url>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.2.1" date="2026-06-24" >
      <description>
        <p>New</p>
        <ul>
          <li>Add section to visualize and edit a document's metadata</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-06-21" >
      <description>
        <p>New</p>
        <ul>
          <li>Add the split PDF functionality</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Make the open file action in the merge page more intuitive</li>
        </ul>
      </description>
    </release>
    <release version="0.1.1" date="2026-06-18" >
      <description>
        <p>New</p>
        <ul>
          <li>Add support for opening password protected files</li>
          <li>Add option to insert blank page</li>
          <li>Add option to duplicate a file in the list view</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Collapse secondary options into a menu</li>
          <li>Add handler to rows for drag and drop</li>
        </ul>
      </description>
    </release>
    <release version="0.1.0" date="2026-06-17" >
      <description>
        <p>Initial release</p>
        <ul>
          <li>Merge and rotate PDF files</li>
        </ul>
      </description>
    </release>
  </releases>

  <developer id="com.fvtronics">
    <name translate="no">Francisco Vásquez Cuevas</name>
  </developer>
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>  
  <update_contact>fvasquez.public@fvtronics.com</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
</component>
