<?xml version="1.0" encoding="UTF-8"?>
<!-- Francisco Vásquez Cuevas 2019 <fvasquez.public@fvtronics.com> -->
<component type="desktop-application">
  <id>@app-id@</id>
  <metadata_license>CC0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Shears</name>
  <summary>Combine and edit PDF files</summary>
  <description>
    <p>Shears is a simple GNOME utility for working with local PDF files without a complex document suite.</p>
    <p>Merge multiple PDFs, organize pages, extract page ranges, split documents, compress files, and edit metadata without relying on online services.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/merge.png</image>
      <caption>Merge multiple PDF files into a single document</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/organize.png</image>
      <caption>Organize and remove a document's pages</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/extract.png</image>
      <caption>Extract selected pages into a new document</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/split.png</image>
      <caption>Split a PDF into multiple documents</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/compress.png</image>
      <caption>Compress a PDF file</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/watermark.png</image>
      <caption>Add a watermark to specific PDF pages</caption>
    </screenshot>
    <screenshot>
      <image>https://codeberg.org/fvtronics/shears/raw/tag/v0.4.0/data/resources/screenshots/metadata.png</image>
      <caption>View and edit PDF metadata</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://www.fvtronics.com/en/project/shears</url>
  <url type="bugtracker">https://codeberg.org/fvtronics/shears/issues</url>
  <url type="vcs-browser">https://codeberg.org/fvtronics/shears</url>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="0.4.0" date="2026-07-07" >
      <description>
        <p>New</p>
        <ul>
          <li>Add tool to watermark PDF files</li>
        </ul>
      </description>
    </release>
    <release version="0.3.1" date="2026-07-07" >
      <description>
        <p>New</p>
        <ul>
          <li>Add option to extract specific pages from a PDF file</li>
        </ul>
      </description>
    </release>
    <release version="0.3.0" date="2026-07-02" >
      <description>
        <p>New</p>
        <ul>
          <li>Add section to organize and remove a document's pages</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-06-26" >
      <description>
        <p>New</p>
        <ul>
          <li>Add section to compress PDF files</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-06-24" >
      <description>
        <p>New</p>
        <ul>
          <li>Add section to visualize and edit a document's metadata</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-06-21" >
      <description>
        <p>New</p>
        <ul>
          <li>Add the split PDF functionality</li>
        </ul>
        <p>Changes</p>
        <ul>
          <li>Make the open file action in the merge page more intuitive</li>
        </ul>
      </description>
    </release>
  </releases>

  <developer id="com.fvtronics">
    <name translate="no">Francisco Vásquez Cuevas</name>
  </developer>
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>  
  <update_contact>fvasquez.public@fvtronics.com</update_contact>
  <translation type="gettext">@gettext-package@</translation>
  <launchable type="desktop-id">@app-id@.desktop</launchable>
</component>
